# SpaceOS 거점 점수 파이프라인 — 실측 API 키 (.env)
# 사용법: 이 파일을 .env 로 복사 후 값 채우기 → `set -a; source data/.env; set +a` 또는 python-dotenv 로 로드.
# 키가 없는 기준은 자동으로 프록시(base 앵커)로 폴백한다.

# ── FOOT 유동인구 + 상권분석 시계열 : 서울 열린데이터광장 ─────────────
# 발급: https://data.seoul.go.kr → 로그인 → 인증키 신청
# 같은 키로 생활인구(Page) + 상권분석서비스(Platform: 추정매출·점포·개폐업률) 모두 호출.
# 상권분석 서비스명 예: VwsmTrdarSelngQq(추정매출) VwsmTrdarStorQq(점포) — docs/api-keys-and-specs.md §8-A
SEOUL_OPENAPI_KEY=
# 구독한 '서울 생활인구' 데이터셋의 서비스명/필드명(데이터셋마다 다름. 상세페이지 '미리보기'에서 확인)
SEOUL_LIVING_POP_SERVICE=SPOP_LOCAL_RESD_DONG
SEOUL_LIVING_POP_SGG_FIELD=SGG_CD
SEOUL_LIVING_POP_VALUE_FIELD=TOT_LVPOP_CO

# ── MAP 지도/IT 유입 & SNS 블로그 : 네이버 개발자센터 ──────────────────
# 발급: https://developers.naver.com → 애플리케이션 등록 → 데이터랩(검색어트렌드)+검색 API 사용 설정
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── SNS 업로드 : 인스타그램 Graph API (선택, 비즈니스 계정 필요) ──────────
# 발급: https://developers.facebook.com → 비즈니스 앱 → instagram_basic + 해시태그 권한
INSTAGRAM_ACCESS_TOKEN=
IG_USER_ID=

# ── VAC 공실 : 소상공인 상가정보 API (선택, density 모드일 때만) ─────────
# 발급: https://www.data.go.kr/data/15012005/openapi.do → 활용신청 → 디코딩 인증키
DATA_GO_KR_SERVICE_KEY=
# base=공식 공실률 앵커(권장) / density=소상공인 점포밀도 프록시
VACANCY_MODE=base

# ── 인구밀도 : 통계청 SGIS (총조사 총인구·인구밀도) ───────────────────
# 발급: https://sgis.kostat.go.kr/developer → 서비스 신청 → 테스트키 즉시발급(consumer_key/secret)
# 사용: auth/authentication.json 으로 accessToken(4h) 발급 후 stats/population.json 호출
SGIS_CONSUMER_KEY=
SGIS_CONSUMER_SECRET=

# ── [B단계·Platform] 개·폐업 인허가 이력 : 지방행정 인허가 (data.go.kr 이관) ─
# ※ localdata.go.kr 은 2026-04-16 폐쇄 — 인허가 195종이 공공데이터포털로 통합 개방됨.
#   data.go.kr 에서 '행정안전부 인허가'(업종별, 예: 일반음식점) 검색 → 활용신청 →
#   위 DATA_GO_KR_SERVICE_KEY 공용. 별도 키 불필요. (구 LOCALDATA_API_KEY 슬롯 폐기)
# 용도: 폐업일자·영업상태 → LSTM 라벨 + 공실 히스토리. 수집기 이관은 data/collectors/localdata.py TODO 참조.

# ── 건물 폴리곤 : V-World 디지털트윈국토 (GIS건물통합 WFS/데이터API) ──────
# 발급: vworld.kr 로그인 → 인증키 발급 (도메인 http://localhost:5173 등록, 즉시발급)
# ※ 舊 국가공간정보포털(nsdi)은 2024-01 폐쇄 — GIS건물통합정보는 V-World로 이관됨.
#   data.go.kr 15083092(파일)·15123970(WMS/WFS)은 V-World로 연결되는 링크 페이지다.
VWORLD_API_KEY=

# ── [B단계·Program/Posting] 장소·카테고리 크로스체크 : 카카오 로컬 ───────
# 발급: https://developers.kakao.com → 애플리케이션 추가 → REST API 키 (즉시발급)
# 호출: https://dapi.kakao.com/v2/local/search/keyword.json — 헤더 Authorization: KakaoAK {KEY}
KAKAO_REST_API_KEY=
